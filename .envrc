# Gabagool Bot - direnv configuration (Mac/zsh)
#
# Auto-activates the virtual environment when you cd into this directory.
#
# Setup (one-time):
#   1. brew install direnv
#   2. Add to ~/.zshrc: eval "$(direnv hook zsh)"
#   3. Open a new terminal, cd here, then: direnv allow
#
# After setup, the venv activates automatically on every cd.

# Create and activate .venv using direnv's built-in layout
# This is the correct direnv idiom (not raw `source`)
layout python3 /opt/homebrew/bin/python3.11

# Load environment variables from config/.env if it exists
if [ -f "config/.env" ]; then
    dotenv config/.env
fi

# Show activation message
echo "✓ Gabagool environment activated (.venv)"
echo "  Run: make run       → dry-run mode"
echo "  Run: make run-live  → live trading (careful!)"
